{
  "name": "douyin-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Douyin video upload automation",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "douyin-login": "./dist/scripts/login.js",
    "douyin-upload": "./dist/scripts/upload.js",
    "douyin-manage": "./dist/scripts/manage.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "login": "tsx ../scripts/login.ts",
    "upload": "tsx ../scripts/upload.ts",
    "manage": "tsx ../scripts/manage.ts"
  },
  "keywords": [
    "mcp",
    "douyin",
    "video",
    "upload",
    "automation",
    "skills"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "puppeteer": "^23.11.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
